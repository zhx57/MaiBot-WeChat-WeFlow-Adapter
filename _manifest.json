{
  "manifest_version": 2,
  "id": "akasha.wechat-weflow-adapter",
  "version": "1.0.0",
  "name": "Akasha WeChat WeFlow 适配器",
  "description": "把微信（经 WeFlow SSE）接入 MaiBot 的双工消息网关适配器，移植自 Akasha-WeChat。",
  "author": {
    "name": "Akasha",
    "url": "https://github.com/alingalingling/Akasha-WeChat"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/alingalingling/Akasha-WeChat",
    "issues": "https://github.com/alingalingling/Akasha-WeChat/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    { "type": "python_package", "name": "aiohttp", "version_spec": ">=3.9.0" },
    { "type": "python_package", "name": "cachetools", "version_spec": ">=5.3.0" },
    { "type": "python_package", "name": "pyperclip", "version_spec": ">=1.8.2" },
    { "type": "python_package", "name": "uiautomation", "version_spec": ">=2.0.17" }
  ],
  "plugin_type": "adapter",
  "capabilities": ["send_message"],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": ["zh-CN"]
  }
}
