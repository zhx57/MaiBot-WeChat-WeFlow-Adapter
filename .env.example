# WeMai 环境变量示例文件
# 复制此文件为 .env 并根据需要修改配置

# 微信监听配置
# 要监听的聊天对象列表，多个用逗号分隔
WX_TARGET_CHATS=test1,test2
# 需要可靠指定类型时可使用 JSON：
# WX_TARGET_CHATS=[{"name":"项目群","type":"group"},{"name":"张总","type":"private"}]

# 是否在未指定目标聊天时监听所有聊天 (true/false)
WX_LISTEN_ALL_IF_EMPTY=false

# 排除的聊天对象，多个用逗号分隔
WX_EXCLUDED_CHATS=文件传输助手,微信团队,微信支付

# 黑名单模式 (true/false)
# 启用后忽略 WX_TARGET_CHATS 白名单，监听除黑名单外的所有聊天。
# 仅在 WeFlow 推送启用 (WEFLOW_PUSH_ENABLED=true) 时生效。
WX_BLACKLIST_MODE=false

# 按需打开窗口 (true/false)
# 启用后不在启动时一次性打开全部目标窗口，仅在发送消息时按需打开，
# 打开后保持检测。默认跟随 WEFLOW_PUSH_ENABLED。
# WX_OPEN_WINDOWS_ON_DEMAND=true

# WeFlow 接收模式（默认启用）。Token 必须与 WeFlow API 服务设置一致。
WEFLOW_API_URL=http://127.0.0.1:5031
WEFLOW_API_TOKEN=
WEFLOW_PUSH_ENABLED=true

# wx4py 配置
# 是否在创建客户端时自动连接微信
WX4PY_AUTO_CONNECT=true
# 监听循环间隔（秒）
WX4PY_TICK=0.05
# 兼容参数；到期聊天始终全部扫描，不再按此值截断
WX4PY_BATCH_SIZE=8
# 图片重试时检查的可见尾部行数；新增消息不会按此值截断
WX4PY_TAIL_SIZE=8
# 单次 UIA 控件探测最长等待（秒）；成功路径通常立即返回
WX4PY_UI_LOOKUP_TIMEOUT=0.08
# 界面状态轮询间隔（秒）
WX4PY_UI_POLL_INTERVAL=0.05
# 微信搜索结果最长等待（秒）
WX4PY_SEARCH_TIMEOUT=4.0
# 双击后等待独立窗口就绪的最长时间（秒）
WX4PY_SUBWINDOW_TIMEOUT=8.0
# 独立聊天窗口存活检查间隔（秒）
WX4PY_WINDOW_CHECK_INTERVAL=30
# UI worker 处理全部初始目标的累计时限；0 表示不设总时限
UI_WORKER_STARTUP_TIMEOUT_SECONDS=0
# UI worker 空闲轮询时允许的最长无心跳时间（秒）
UI_WORKER_IDLE_TIMEOUT_SECONDS=30
# UI worker 正在发送、恢复窗口或保存图片时允许的最长无心跳时间（秒）；
# 实际值不会低于 IMAGE_SAVE_TIMEOUT_SECONDS + 15
UI_WORKER_BUSY_TIMEOUT_SECONDS=60
# UIA/COM 卡死被看门狗确认后，是否自动重启当前 WeMai 进程
UI_WORKER_AUTO_RESTART=true

# MaiBot API 配置
# 新版麦麦(>=1.0)用 maim_message 库的纯 WebSocket 服务。
# 地址对应 MaiBot 的 config/bot_config.toml 里 [maim_message] 段：
#   ws_server_host (默认 127.0.0.1) 和 ws_server_port (默认 8000)。
# 本机部署就用 ws://127.0.0.1:8000/ws；远程部署把 127.0.0.1 换成麦麦服务器 IP。
# 注意：端口必须是 ws_server_port（默认 8000），不是 WebUI 端口（默认 8001）。
MAIBOT_API_URL=ws://127.0.0.1:8000/ws
# MaiBot 根目录下的 data 目录；配置后缓存头像到 data/avatar/<platform>/
MAIBOT_DATA_DIR=

# 日志配置
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=wepush.log
LOG_FORMAT=%(asctime)s - %(levelname)s - %(message)s
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S

# 平台标识,如果修改了，请调整maibot中的bot_config.toml中的消息推送平台
PLATFORM_ID=wx4py

# 机器人自己的微信昵称（可选）
# 用于排除把机器人自己当接收者的情况。建议填，多一层保险。
WX_BOT_NICKNAME=麦麦

# 图片下载配置
# 是否启用自动下载图片 (true/false)
IMAGE_AUTO_DOWNLOAD=true

# 自动保存收到的图片到此目录；相对路径以 WeMai 当前工作目录为准
IMAGE_SAVE_DIR=wxauto文件

# 等待微信图片预览和复制完成的最长秒数（1-120）
IMAGE_SAVE_TIMEOUT_SECONDS=10

# 图片识别配置
# 是否启用图像识别功能 (true/false)
IMAGE_RECOGNITION_ENABLED=true

# 队列、媒体和状态文件限制
SEND_QUEUE_SIZE=100
UI_QUEUE_SIZE=100
MAX_MEDIA_BYTES=10485760
MEDIA_DOWNLOAD_TIMEOUT_SECONDS=15
MEDIA_DOWNLOAD_MAX_REDIRECTS=3
ID_MAP_FILE=wemai_id_map.json
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
